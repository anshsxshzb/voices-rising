rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && request.auth.token.email == 'anshsxshzb@gmail.com';
    }
    
    function isReader() {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/readers/$(request.auth.token.email));
    }
    
    function isAuthorized() {
      return isAdmin() || isReader();
    }

    match /articles/{articleId} {
      // Allow read if article is published, or if user is authorized (admin/reader)
      allow read: if resource.data.published == true || isAuthorized();
      
      // Only admin can create or delete articles
      allow create, delete: if isAdmin();
      
      // Admin can update anything. 
      // Readers can update comments, likedBy, and views.
      // Anyone can increment views.
      allow update: if isAdmin() || (
        isReader() && 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['comments', 'likedBy', 'views'])
      ) || (
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['views']) &&
        request.resource.data.views == (resource.data.get('views', 0) + 1)
      );
    }
    
    match /readers/{readerEmail} {
      // Admin can do everything
      allow read, write: if isAdmin();
      // Readers can read their own reader document
      allow read: if isAuthenticated() && request.auth.token.email == readerEmail;
    }

    match /access_requests/{email} {
      // Admin can read, update, and delete requests
      allow read, update, delete: if isAdmin();
      // Any authenticated user can read and create a request for themselves
      allow read, create: if isAuthenticated() && request.auth.token.email == email;
    }
  }
}
